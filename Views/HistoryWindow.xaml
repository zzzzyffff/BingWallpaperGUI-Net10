<Window x:Class="BingWallpaperWPF.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BingWallpaperWPF.ViewModels"
        xmlns:conv="clr-namespace:BingWallpaperWPF.Converters"
        Title="历史壁纸" Height="600" Width="850"
        MinWidth="600" MinHeight="400"
        Background="#1e1e1e" Foreground="#e0e0e0"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d">
    <Window.Resources>
        <conv:FilePathToThumbnailConverter x:Key="FilePathToThumbnailConverter"/>
        <conv:BingDateConverter x:Key="BingDateConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="已下载的壁纸" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="还没有下载过壁纸" Foreground="#888888" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsEmpty, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Wallpapers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2d2d2d" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail -->
                                <Border Grid.Column="0" Width="180" Height="120" Background="#1e1e1e"
                                        CornerRadius="4" ClipToBounds="True">
                                    <Image Source="{Binding File.FullName, Converter={StaticResource FilePathToThumbnailConverter}}"
                                           Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Text Info -->
                                <StackPanel Grid.Column="1" Margin="15,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title, FallbackValue='Bing 壁纸'}" Foreground="#e0e0e0"
                                               FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Copyright}" Foreground="#aaaaaa"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Foreground="#666666" FontSize="12" Margin="0,4,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}  |  {1}  |  {2}">
                                                <Binding Path="Date" Converter="{StaticResource BingDateConverter}"/>
                                                <Binding Path="Resolution"/>
                                                <Binding Path="Locale"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Buttons -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Button Content="设为壁纸" Background="#0078d4" Foreground="White"
                                            Padding="12,5" Margin="0,0,0,6"
                                            Command="{Binding DataContext.SetWallpaperCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="打开文件" Background="#3c3c3c" Foreground="#e0e0e0"
                                            Padding="12,5" Margin="0,0,0,6"
                                            Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="删除" Background="#8b0000" Foreground="White"
                                            Padding="12,5"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
